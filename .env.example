# Copy this file to backend/.env and fill in your Alpaca credentials.
# NEVER commit the real .env. (It is gitignored.)

# --- Alpaca credentials (Algo Trader Plus, SIP real-time data) ---
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_here

# --- Trading mode ---
# false = LIVE (real money, api.alpaca.markets)
# true  = PAPER (paper-api.alpaca.markets) -- recommended for first dry run
ALPACA_PAPER=false

# --- Market data feed ---
# sip = full real-time consolidated feed (requires Algo Trader Plus)
# iex = free, limited
ALPACA_DATA_FEED=sip

# --- Symbols (comma separated) ---
SYMBOLS=SNDK,SPCX,STX,NVDA,MRVL

# --- Server ---
HTTP_ADDR=:8080
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Safety: reject any single order whose value exceeds this (USD). 0 disables. ---
MAX_ORDER_NOTIONAL=25000

# --- News enrichment for DECEPTICON movers "why is it moving?" (ALL OPTIONAL) ---
# Gemini writes the on-click plain-English summary (reads the article link).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_RPM=8            # self-imposed ceiling, stays under the free per-minute limit
GEMINI_DAILY_CAP=200    # self-imposed daily ceiling

# --- Dip Watcher Telegram bot (OPTIONAL) ---
# Alerts when watchlist stocks dip into an oversold pullback and print a green bounce.
# Disabled unless both the token and chat ID are set. Get the chat ID by messaging the
# bot, then reading https://api.telegram.org/bot<TOKEN>/getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI quant pipeline (Paper · Claude page) — ALL OPTIONAL ---
# Every paper desk needs its OWN Alpaca PAPER account. Desks sharing an account
# liquidate each other's shares and corrupt each other's position tracking.
# A SEPARATE Alpaca PAPER account for the SIGNAL desk (6-strategy engine + judge).
PAPER_CLAUDE_KEY=
PAPER_CLAUDE_SECRET=
# A SEPARATE Alpaca PAPER account for the DIP+RISE desk (Agent 2 dips + rise watcher).
# Empty = that family stays shadow even when QUANT_LIVE/QUANT_RISE_LIVE are true.
PAPER_DIP_KEY=
PAPER_DIP_SECRET=
# A SEPARATE Alpaca PAPER account for the RBT (Rubber Band Trading) strategy.
PAPER_RBT_KEY=
PAPER_RBT_SECRET=
# A SEPARATE Alpaca PAPER account for the RIDP desk (RIDER + DIPPER + REVERTER).
# STRICT one account per desk: empty keys = desk OFF (no fallback to another account).
PAPER_RIDP_KEY=
PAPER_RIDP_SECRET=
# A SEPARATE Alpaca PAPER account for the SNDK 1-minute scalper (empty = benched).
PAPER_SNDK_KEY=
PAPER_SNDK_SECRET=
# Anthropic key for the entry/exit/review agents. Empty = agents stay idle (zero cost).
ANTHROPIC_API_KEY=
# Extra symbols always streamed for the pipeline (SPY/QQQ are added automatically).
CLAUDE_SYMBOLS=SNDK,MU
# Agent models + risk knobs.
QUANT_ENTRY_MODEL=claude-haiku-4-5
QUANT_EXIT_MODEL=claude-haiku-4-5
QUANT_REVIEW_MODEL=claude-opus-4-8
QUANT_TRAIL_PCT=1.5     # deterministic trailing-stop floor (%)
QUANT_LIVE=true         # dip+rise desk: false = shadow (decide + log only, no paper orders)
# Overnight: keep at most ONE profitable position up to this VALUE past the close (0 = flatten all).
QUANT_OVERNIGHT_CAP=0
# Signal-engine universe file (default: QUANT_UNIVERSE.json at the repo root).
#QUANT_UNIVERSE_PATH=
# Signal-engine PAPER execution (the validated all-strategies + time-of-day-gate config):
# signal -> TOD gate -> LLM judge veto -> allocator -> manager -> paper broker.
QUANT_SIGNALS_LIVE=true
# Rise watcher (confirmed post-dip rises): false = shadow (journals + Telegram only).
QUANT_RISE_LIVE=false
# RIDP deterministic desk (RIDER + DIPPER + REVERTER): false = shadow journaling.
RIDP_LIVE=true
QUANT_JUDGE_MODEL=claude-haiku-4-5
QUANT_DAILY_LOSS_CAP=150   # halt new signal entries once day P&L hits -cap (USD)
# Time-of-day gate enforcement. Default false (shadow-only) since the 2026-07
# re-validation: the gate's edge did not survive a regime change (see RESEARCH_BACKLOG
# #3). Buckets keep journaling/learning (with exponential decay) either way; set true
# to re-enforce without a code change.
#QUANT_TOD_GATE=false
# ML entry gate (RESEARCH_BACKLOG #15 — passed the full promotion bar): nightly-trained
# per-strategy LightGBM classifiers reject entries with expected R below 0.03.
# Fail-open: no fresh models = no gating. QUANT_RETRAIN auto-runs ml/train_live.py each
# weekday ~17:05 ET so the models walk forward with the live journal.
QUANT_CLF_GATE=true
QUANT_RETRAIN=true
# Agent 4 (sentiment) runs on a local Ollama model (advisory only).
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
# Pre-market Strategist agent (posture + allocation -> data/daily_universe.json).
QUANT_STRATEGIST=true
QUANT_STRATEGIST_MODEL=claude-opus-4-8
# Research loop: auto-runs at 13:30 ET weekdays (open + 4h), reports to Telegram.
RESEARCH_LOOP=true

# --- Throughput-mode dials (2026-07-16) — ALL OPTIONAL ---
# Entry gates were loosened for the paper measurement month; every dial is
# env-overridable back to its original value. Full table + originals: THROUGHPUT_MODE.md.
# Examples (uncomment to roll back a dial):
#RIDP_RIDER_GAIN_MIN=0.01
#RIDP_RIDER_RVOL_MIN=2.0
#RIDP_DIPPER_TURN_PCT=0
#QUANT_CLF_MARGIN=0.03
#QUANT_ALIGN_STRICT=true
#RBT_Z_ENTRY=2.5
#RBT_PROB_MIN=0.65
# Mechanical exit rails (units of each trade's planned risk R; 0 disables):
#QUANT_EXIT_GRACE_MIN=10
#QUANT_BREAKEVEN_R=0.5
#QUANT_CHK_HALF_R=0.75
#QUANT_CHK_FULL_R=0.5
#QUANT_EXIT_NOISE_R=0.25
